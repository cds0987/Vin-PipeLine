# Copy to .env for local development. Do not commit .env.

# AI provider
AI_PROVIDER=auto
AI_BASE_URL=
AI_API_KEY=
EMBED_MODEL=text-embedding-3-small
VISION_MODEL=gpt-4o
EMBEDDING_DIM=1536

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Vector store
VECTOR_STORE=chroma
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=documents

# Metadata store
METADATA_STORE=postgres
DATABASE_URL=postgresql://rag:rag@postgres:5432/ragdb

# Storage
USE_S3=false
S3_BUCKET=rag-pipeline-local
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Kafka
KAFKA_BOOTSTRAP=kafka:9092

# Auto mode behavior
# - AI_BASE_URL empty + AI_API_KEY set   -> use OpenAI default base URL
# - AI_BASE_URL set   + AI_API_KEY set   -> call that URL with current model config
# - AI_API_KEY empty                      -> use mock provider

# OpenRouter example
# AI_PROVIDER=auto
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=sk-or-v1-...
# EMBED_MODEL=openai/text-embedding-3-small
# VISION_MODEL=openai/gpt-4o-mini

# Force real OpenAI mode
# AI_PROVIDER=openai
# AI_BASE_URL=
# AI_API_KEY=sk-...
