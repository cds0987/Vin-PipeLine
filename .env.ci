# .env.ci — CI environment contract.
#
# This file is committed and is the SINGLE source of truth for env vars
# used in CI jobs. When config/settings.py adds a new variable, update
# this file — CI YAML never needs to change.
#
# DO NOT put secrets here. Secrets come from GitHub Secrets → applied
# via make apply-secret or kubectl.

AI_PROVIDER=mock
VECTOR_STORE=memory
METADATA_STORE=memory
USE_S3=false

EMBEDDING_DIM=32
EMBED_MODEL=text-embedding-3-small
VISION_MODEL=gpt-4o

MARKDOWN_S3_PREFIX=rag-derived/markdown
CAPTION_MODEL=heuristic
PARSER_VERSION=pipeline.parsers.v1

SECTION_FALLBACK_MAX_CHARS=2400
SECTION_FALLBACK_PARAGRAPHS=3
CAPTION_MAX_CHARS=280

SCAN_INTERVAL_SECONDS=0
SCAN_MAX_WORKERS=4
SEARCH_SCORE_THRESHOLD=0.5
SEARCH_QUERY_MAX_LENGTH=2000
STALE_INDEXING_SECONDS=3600
