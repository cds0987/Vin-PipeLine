# Normalize line endings: LF in repo, OS-native on checkout
* text=auto eol=lf

# Force LF for Python and config files regardless of OS
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.env text eol=lf
*.txt text eol=lf
*.ps1 text eol=crlf

# Binary files — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.bmp binary
*.tiff binary
*.pdf binary
*.docx binary
